  "test_scenarios": {
    "auth_bypass": {
      "description": "Test accessing protected endpoints without authentication",
      "test_unauthenticated_access": true,
      "test_wrong_role_access": true
    },
    "csrf": {
      "description": "Test CSRF token enforcement on POST endpoints",
      "test_missing_csrf": true
    },
    "idor": {
      "description": "Test Insecure Direct Object Reference by accessing other users resources",
      "test_sequential_ids": [1, 2, 3, 999, 9999]
    },
    "input_validation": {
      "description": "Test input validation on form fields",
      "xss_payloads": ["<script>alert('XSS')</script>", "'\"><img src=x onerror=alert(1)>", "javascript:alert(1)"],
      "sqli_payloads": ["' OR '1'='1", "\" OR \"1\"=\"1", "'; DROP TABLE users;--", "1' UNION SELECT NULL--"],
      "path_traversal": ["../../../etc/passwd", "..\\..\\..\\windows\\system32\\config\\sam"]
    },
    "rate_limiting": {
      "description": "Test rate limiting on login and sensitive endpoints",
      "rapid_request_count": 20,
      "target_endpoints": ["/", "/check_email_existence/", "/verify_otp/"]
    },
    "http_methods": {
      "description": "Test unsupported HTTP methods on endpoints",
      "methods_to_test": ["PUT", "DELETE", "PATCH", "OPTIONS", "TRACE"]
    },
    "navigation_patterns": {
      "description": "Non-standard UI elements to handle during navigation",
      "django_patterns": {
        "csrf_token": "csrfmiddlewaretoken",
        "login_form_selectors": ["form[method='post']", "#login-form", "form[action='/']"],
        "common_selectors": {
          "sidebar_nav": [".sidebar", "#sidebar", "nav.sidebar", ".side-nav", ".sidenav"],
          "dropdown_menu": [".dropdown", ".dropdown-toggle", ".dropdown-menu"],
          "modal_dialog": [".modal", ".modal-dialog", ".modal-content", "[data-bs-toggle='modal']", "[data-toggle='modal']"],
          "data_tables": [".dataTables_wrapper", "#dataTable", "table.dataTable", ".table-responsive"],
          "ajax_loader": [".loading", ".spinner", "#loading", ".preloader", "[data-loading]"],
          "toast_alert": [".toast", ".alert", ".notification", ".swal2-container"],
          "tab_panels": [".nav-tabs", ".tab-content", "[data-bs-toggle='tab']", "[data-toggle='tab']"],
          "accordion": [".accordion", ".collapse", "[data-bs-toggle='collapse']"],
          "select2": [".select2", ".select2-container", ".select2-selection"],
          "datepicker": [".datepicker", ".daterangepicker", "[type='date']"],
          "file_upload": ["input[type='file']", ".custom-file-input", ".dropzone"],
          "search_input": ["input[type='search']", ".search-input", "#search", "[name='q']"],
          "pagination": [".pagination", ".page-link", ".paginate_button"]
        }
      }
    }
  }
